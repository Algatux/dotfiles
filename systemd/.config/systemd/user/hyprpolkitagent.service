[Unit]
Description=Hyprland Polkit Authentication Agent
# Ensures the agent is ready only when the graphical session is active
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
# Safety check to ensure the Wayland socket is ready
ExecStartPre=/usr/bin/bash -c 'until [ -n "$WAYLAND_DISPLAY" ]; do sleep 0.1; done'
ExecStart=/usr/lib/hyprpolkitagent/hyprpolkitagent
Restart=on-failure
RestartSec=5

[Install]
# Links the agent to the graphical session instead of the generic boot
WantedBy=graphical-session.target